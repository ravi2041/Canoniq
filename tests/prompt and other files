sql_code = """

            -- Params: {{start_date}}, {{end_date}}, {{dims}} e.g. 'LOWER(campaign) AS campaign, site'
            WITH
            fb AS (
              SELECT {{dims}},
                     SUM(impressions) impressions, SUM(clicks) clicks, SUM(cost) spend,
                     0 total_conversions
              FROM facebook_data
              WHERE date BETWEEN {{start_date}} AND {{end_date}}
              GROUP BY {{dims}}
            ),
            yt AS (
              SELECT {{dims}},
                     SUM(impressions) impressions, SUM(clicks) clicks, SUM(cost) spend,
                     0 total_conversions
              FROM youtube_data
              WHERE date BETWEEN {{start_date}} AND {{end_date}}
              GROUP BY {{dims}}
            ),
            tt AS (
              SELECT {{dims}},
                     SUM(impressions) impressions, SUM(clicks) clicks, SUM(cost) spend,
                     0 total_conversions
              FROM tiktok_data
              WHERE date BETWEEN {{start_date}} AND {{end_date}}
              GROUP BY {{dims}}
            ),
            cm AS (
              SELECT {{dims}},
                     0 impressions, 0 clicks, 0 spend,
                     SUM(conversions) total_conversions
              FROM cm360_conversion_data
              WHERE date BETWEEN {{start_date}} AND {{end_date}}
              GROUP BY {{dims}}
            ),
            stacked AS (
              SELECT * FROM fb
              UNION ALL SELECT * FROM yt
              UNION ALL SELECT * FROM tt
              UNION ALL SELECT * FROM cm
            )
            SELECT {{dims}},
                   SUM(impressions) AS impressions,
                   SUM(clicks)      AS clicks,
                   SUM(spend)       AS spend,
                   SUM(total_conversions) AS conversions,
                   SUM(clicks) / NULLIF(SUM(impressions), 0)      AS ctr,
                   SUM(spend)  / NULLIF(SUM(clicks), 0)           AS cpc,
                   SUM(total_conversions) / NULLIF(SUM(clicks), 0) AS cvr,
                   SUM(spend)  / NULLIF(SUM(total_conversions), 0) AS cpa
            FROM stacked
            GROUP BY {{dims}};

            """

